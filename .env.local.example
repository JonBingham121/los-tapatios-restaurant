# Example environment variables file
# Copy this to .env.local and fill in your values

# GitHub credentials (for deployment automation)
GITHUB_USER=your-github-username
GITHUB_TOKEN=your-github-token

# Vercel credentials (for deployment automation)
VERCEL_TOKEN=your-vercel-token

# Note: These are only needed for automated deployment scripts
# Manual deployment through Vercel dashboard doesn't require these
